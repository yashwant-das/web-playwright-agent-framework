#!/bin/sh


commit_msg_file=$1
first_line=$(head -n 1 "$commit_msg_file")

# Ignore merge commits
if echo "$first_line" | grep -qE "^Merge"; then
  exit 0
fi

# Regex check
# Types: feat, fix, refactor, test, docs, chore, build, arch, heal, map
# Scope: optional, lowercase alphanumeric + dashes
pattern="^(feat|fix|refactor|test|docs|chore|build|arch|heal|map)(\([a-z0-9-]+\))?: .+$"

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "Invalid commit message: $first_line"
  echo ""
  echo "Expected: <type>(<optional-scope>): <subject>"
  echo "Types: feat, fix, refactor, test, docs, chore, build, arch, heal, map"
  echo "Scopes: (optional) cli, protocol, tasks, deps, selectors, login, products, cart, checkout"
  echo ""
  echo "Examples:"
  echo "  feat(cli): add task generator"
  echo "  fix(tasks): handle blocked task parsing"
  echo "  refactor(protocol): simplify task state logic"
  echo "  docs(protocol): update SPP workflow"
  echo "  build(deps): upgrade playwright"
  echo "  arch(spp): introduce protocol authority"
  echo "  heal(selectors): repair checkout locator"
  echo ""
  exit 1
fi
